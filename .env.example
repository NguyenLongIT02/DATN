# ===================================================
# Docker Compose Environment Variables
# Copy file này thành .env và điền thông tin thật
# ===================================================

# Database Configuration
DB_NAME=todoapp
DB_USERNAME=postgres
DB_PASSWORD=your_strong_db_password_here
DB_PORT=5432

# Redis Configuration
REDIS_PASSWORD=your_strong_redis_password_here
REDIS_PORT=6379

# Backend Server Port
SERVER_PORT=8081

# JWT Configuration (PHẢI đổi thành key bảo mật thật - ít nhất 256 bits)
JWT_SECRET_KEY=your_jwt_secret_key_here_must_be_at_least_256_bits_long_and_secure
JWT_REFRESH_KEY=your_jwt_refresh_key_here_must_be_at_least_256_bits_long_and_secure
JWT_EXPIRATION=1800000
JWT_EXPIRATION_REFRESH_TOKEN=1209600000

# API Configuration
API_PREFIX=/api/v1
DOMAIN_PROTOCOL=http://localhost:8081
SWAGGER_UI_PATH=/swagger-ui.html

# Mail Configuration
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_gmail_app_password_here
